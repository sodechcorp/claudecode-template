      "mcp__backlog__add_issue_comment",
      "mcp__backlog__add_pull_request_comment",
      "mcp__backlog__update_pull_request_comment",
      "mcp__backlog__update_issue",
      "mcp__backlog__add_issue",
      "mcp__backlog__delete_issue",
      "mcp__backlog__add_pull_request",
      "mcp__backlog__update_pull_request",
      "mcp__backlog__delete_project",
      "mcp__backlog__delete_version",
      "mcp__backlog__delete_watching",
