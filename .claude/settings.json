{
  "env": {
    "_comment_PYTHONIOENCODING": "Windows の Python はデフォルト stdout が cp932。Claude Code は UTF-8 期待のため、print('小俣') 等が化ける。全 Python 実行を UTF-8 stdout に統一する。",
    "PYTHONIOENCODING": "utf-8"
  },
  "hooks": {
    "PreCompact": [
      {
        "matcher": "auto|manual",
        "hooks": [
          {
            "type": "command",
            "command": "echo '{\"systemMessage\":\"[SAVE-BEFORE-COMPACT] 圧縮前に知見を保存せよ。保存先と対象: (1) docs/logs/dev-notes.md — 技術知見・発見した制約（スクリプト設計・外部ツール連携等）を追記 (2) docs/knowledge/pitfalls.md — 落とし穴・ハマりポイント・注意事項 (3) docs/decisions.md — 方針判断・設計決定（最上部に降順追記） (4) .claude/agents/ — 設計判断・スキーマ変更・エージェントへの制約追加が必要なものを該当agentファイルに追記。すべてプロジェクト相対パス。Write/Editで今すぐ実行してから圧縮を続行。変更不要なら何もしない。(5) /backlog コマンド実行中の場合は、compact 前に docs/logs/{issueID}/investigation.md のフロントマター（issue_type / xlsx_folder / evidence_dir / light_mode）が最新の状態で保存されているか確認してください。compact 後に /backlog を再開する場合は、最初に /backlog {課題ID}（対応中の課題ID）を打ち直してください。Phase 0d が investigation.md のフロントマターからコンテキストを復元します。\"}'",
            "timeout": 10
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash|Write|Edit|MultiEdit|mcp__backlog__.*",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/pre-operation.js",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/post-query-reminder.js",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(*)",
      "Bash(python scripts/python/git-sync/git-sync-merge.py --branch *)",
      "mcp__backlog__*"
    ],
    "deny": [
      "Bash(sf project deploy* --target-org *prod*)",
      "Bash(sf project deploy* --target-org *production*)",
      "Bash(sf project deploy* -o *prod*)",
      "Bash(sf project deploy* -o *production*)",
      "Bash(sf metadata deploy* --target-org *prod*)",
      "Bash(sf metadata deploy* --target-org *production*)",
      "Bash(sf metadata deploy* -o *prod*)",
      "Bash(sf metadata deploy* -o *production*)",
      "Bash(sf data upsert* --target-org *prod*)",
      "Bash(sf data upsert* --target-org *production*)",
      "Bash(sf data upsert* -o *prod*)",
      "Bash(sf data upsert* -o *production*)",
      "Bash(sf data delete* --target-org *prod*)",
      "Bash(sf data delete* --target-org *production*)",
      "Bash(sf data delete* -o *prod*)",
      "Bash(sf data delete* -o *production*)",
      "Bash(sf data update* --target-org *prod*)",
      "Bash(sf data update* --target-org *production*)",
      "Bash(sf data update* -o *prod*)",
      "Bash(sf data update* -o *production*)",
      "Bash(sf data create* --target-org *prod*)",
      "Bash(sf data create* --target-org *production*)",
      "Bash(sf data create* -o *prod*)",
      "Bash(sf data create* -o *production*)",
      "Bash(sf data import* --target-org *prod*)",
      "Bash(sf data import* --target-org *production*)",
      "Bash(sf data import* -o *prod*)",
      "Bash(sf data import* -o *production*)",
      "Bash(sf data bulk* --target-org *prod*)",
      "Bash(sf data bulk* --target-org *production*)",
      "Bash(sf data bulk* -o *prod*)",
      "Bash(sf data bulk* -o *production*)",
      "Bash(sf data resume* --target-org *prod*)",
      "Bash(sf data resume* --target-org *production*)",
      "Bash(sf data resume* -o *prod*)",
      "Bash(sf data resume* -o *production*)",
      "Bash(sf apex run* --target-org *prod*)",
      "Bash(sf apex run* --target-org *production*)",
      "Bash(sf apex run* -o *prod*)",
      "Bash(sf apex run* -o *production*)",
      "Bash(sf package install* --target-org *prod*)",
