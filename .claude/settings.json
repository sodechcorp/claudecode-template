{
  "env": {
    "_comment_PYTHONIOENCODING": "Windows の Python はデフォルト stdout が cp932。Claude Code は UTF-8 期待のため、print('小俣') 等が化ける。全 Python 実行を UTF-8 stdout に統一する。",
    "PYTHONIOENCODING": "utf-8"
  },
  "hooks": {
    "PreCompact": [
      {
        "matcher": "auto|manual",
        "hooks": [
          {
            "type": "command",
            "command": "echo '{\"systemMessage\":\"[SAVE-BEFORE-COMPACT] 圧縮前に知見を保存せよ。保存先と対象: (1) C:/workspace/claude-temp/docs/logs/dev-notes.md — diagram_gen.py・Graphviz設定・スクリプト設計の技術知見・発見した制約 (2) C:/workspace/claude-temp/.claude/agents/ — 設計判断・スキーマ変更・エージェントへの制約追加が必要なものを該当agentファイルに追記 (3) C:/Users/sodech/.claude/projects/c--ClaudeCode/memory/ — SFテンプレートプロジェクトに関するfeedback/projectメモリを更新。この会話で初めて確認した内容のみ。既存と重複は不要。Write/Editで今すぐ実行してから圧縮を続行。変更不要なら何もしない。(4) /backlog コマンド実行中の場合は、compact 前に docs/logs/{issueID}/investigation.md のフロントマター（issue_type / xlsx_folder / evidence_dir / light_mode）が最新の状態で保存されているか確認してください。compact 後の再開には /backlog コマンドの再起動が必要です。\"}'",
            "timeout": 10
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash|Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/pre-operation.js",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(*)",
      "mcp__backlog__*"
    ],
    "deny": [
      "Bash(sf project deploy* --target-org *prod*)",
      "Bash(sf project deploy* --target-org *production*)",
      "Bash(sf project deploy* -o *prod*)",
      "Bash(sf project deploy* -o *production*)",
      "Bash(sf metadata deploy* --target-org *prod*)",
      "Bash(sf metadata deploy* --target-org *production*)",
      "Bash(sf metadata deploy* -o *prod*)",
      "Bash(sf metadata deploy* -o *production*)",
      "Bash(sf data upsert* --target-org *prod*)",
      "Bash(sf data upsert* --target-org *production*)",
      "Bash(sf data upsert* -o *prod*)",
      "Bash(sf data upsert* -o *production*)",
      "Bash(sf data delete* --target-org *prod*)",
