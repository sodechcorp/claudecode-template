      "Bash(sf package uninstall* -o *prod*)",
      "Bash(sf package uninstall* -o *production*)",
      "Bash(sf org delete* --target-org *prod*)",
      "Bash(sf org delete* --target-org *production*)",
      "Bash(sf org delete* -o *prod*)",
      "Bash(sf org delete* -o *production*)",
      "Bash(sf org assign* --target-org *prod*)",
      "Bash(sf org assign* --target-org *production*)",
      "Bash(sf org assign* -o *prod*)",
      "Bash(sf org assign* -o *production*)",
      "Bash(sf org enable* --target-org *prod*)",
